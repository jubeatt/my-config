{
	"name": "simplifier",
	"description": "Code Simplifier Agent that refines code for clarity, consistency, and maintainability while preserving functionality",
	"model": "claude-opus-4.6",
	"tools": ["*"],
	"allowedTools": ["@builtin", "fs_*", "execute_bash"],
	"hooks": {
		"postToolUse": [
			{
				"matcher": "fs_write",
				"command": "~/.kiro/hooks/post-write-format.sh"
			}
		]
	},
	"resources": [
		"file:///Users/peanu/.kiro/steering/*.md",
		"file:///Users/peanu/.kiro/skills/*/SKILL.md",

		"file://.kiro/steering/*.md",
		"skill://.kiro/skills/*/SKILL.md"
	],
	"prompt": "file:///Users/peanu/.kiro/agents/simplifier.md",
	"includeMcpJson": false
}
