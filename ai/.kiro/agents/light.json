{
	"name": "light",
	"description": "General-purpose agent for answering questions, looking things up, and making small changes",
	"model": "claude-opus-4.6",
	"tools": ["*"],
	"allowedTools": [
		"@builtin",
		"fs_*",
		"use_subagent",
		"execute_bash",
		"@context7",
		"@exa",
		"@mcp-atlassian",
		"@figma-developer-mcp"
	],
	"toolsSettings": {
		"subagent": {
			"availableAgents": [
				"designer",
				"developer",
				"explorer",
				"reviewer",
				"simplifier",
				"tester",
				"debugger"
			],
			"trustedAgents": [
				"designer",
				"developer",
				"explorer",
				"reviewer",
				"simplifier",
				"tester",
				"debugger"
			]
		}
	},
	"hooks": {
		"postToolUse": [
			{
				"matcher": "fs_write",
				"command": "~/.kiro/hooks/post-write-format.sh"
			}
		]
	},
	"resources": [
		"file:///Users/peanu/.kiro/steering/*.md",
		"file:///Users/peanu/.kiro/skills/*/SKILL.md",

		"file://.kiro/steering/*.md",
		"skill://.kiro/skills/*/SKILL.md",

		"file://README.md",
		"file://package.json"
	],
	"prompt": "file:///Users/peanu/.kiro/agents/light.md",
	"includeMcpJson": true
}
